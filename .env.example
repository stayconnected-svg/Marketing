# Automated Lead Pipeline — Setup & Configuration
# Copy this file to .env and fill in your API keys

# ─── Apollo.io ───
# Sign up: https://app.apollo.io (free tier: 50 credits)
# Get key: Settings → API → Generate Key
APOLLO_API_KEY=

# ─── Apify ───
# Sign up: https://apify.com (free tier: $5 platform credit/mo)
# Get token: Settings → Integrations → API Token
APIFY_API_TOKEN=

# ─── Instantly.ai ───
# Sign up: https://instantly.ai ($37/mo Growth plan)
# Get key: Settings → API → Copy API Key
INSTANTLY_API_KEY=

# ─── RB2B (optional, for site visitor ID) ───
# Sign up: https://rb2b.com (free tier: 150 IDs/mo)
# Webhook URL gets configured in RB2B dashboard → points to your endpoint
RB2B_WEBHOOK_SECRET=

# ─── Google Analytics 4 (viewership tracking) ───
# Create property: https://analytics.google.com → Admin → Create Property
# Enable API: Google Cloud Console → APIs & Services → Enable "GA4 Data API"
# Service account: Cloud Console → IAM → Service Accounts → Create → download JSON key
# Add service account email as Viewer on your GA4 property
GA4_PROPERTY_ID=
GA4_CREDENTIALS_PATH=ga4_credentials.json
